# MCP bootstrap environment template

# Git / local filesystem / Playwright
GIT_USER_NAME=your-name
GIT_USER_EMAIL=you@example.com
FILESYSTEM_ALLOWED_ROOTS=/home/user/retailflow-backend
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
PLAYWRIGHT_HEADLESS=true

# GitHub MCP
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-org-or-user
GITHUB_REPO=retailflow

# Render MCP
RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxx
RENDER_OWNER_ID=usr-xxxxxxxxxxxx
RENDER_SERVICE_ID_API=srv-xxxxxxxxxxxx
RENDER_SERVICE_ID_FRONTEND=srv-xxxxxxxxxxxx

# Netlify MCP
NETLIFY_AUTH_TOKEN=nfp_xxxxxxxxxxxxxxxxxxxx
NETLIFY_SITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NETLIFY_TEAM_ID=team_xxxxxxxxxxxx

# Optional but recommended MCPs
# Sentry
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx
SENTRY_ORG=your-org
SENTRY_PROJECT=retailflow

# Database / local dev helpers
POSTGRES_URL=postgresql://user:password@localhost:5432/retailflow
REDIS_URL=redis://localhost:6379
